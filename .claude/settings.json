{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go test:*)",
      "Bash(bash -c:*)",
      "Bash(bash -l -c:*)",
      "Bash(git -C:*)",
      "Bash(gh api:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "language": "日本語"
}
