# MCP settings for Claude Code and Codex
# Copy this file to ~/.secrets/mcp.env and fill in real values.
# $ cp mcp.env.example ~/.secrets/mcp.env
# $ chmod 600 ~/.secrets/mcp.env

# Jira
# トークン発行: https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_URL=https://your-company.atlassian.net
export JIRA_USERNAME=your.email@example.com
export JIRA_API_TOKEN=

# Kibela
# トークン発行: https://your-subdomain.kibe.la/settings/access_tokens
export KIBELA_ORIGIN=https://your-subdomain.kibe.la
export KIBELA_ACCESS_TOKEN=

# Linear
# トークン発行: https://linear.app/settings/api (Personal API Keys)
export LINEAR_API_KEY=

# GitHub
# トークン発行: https://github.com/settings/personal-access-tokens
export GITHUB_PERSONAL_ACCESS_TOKEN=

# Metabase
# Metabase v0.49 未満では API Key が使えないため、user/password 認証を使用
# SSO ユーザーは Admin → People → 自分 → Reset Password でパスワード設定が必要
export METABASE_URL=https://metabase.example.com
export METABASE_USERNAME=your.email@example.com
export METABASE_PASSWORD=
